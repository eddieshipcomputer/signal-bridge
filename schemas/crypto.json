{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Crypto Signal Schema",
  "description": "Signal schema for crypto perpetuals (Hyperliquid, etc)",
  "allOf": [
    { "$ref": "base.json" },
    {
      "type": "object",
      "properties": {
        "funding_rate_threshold": {
          "type": ["number", "null"],
          "description": "Max acceptable funding rate (e.g. 0.001 = 0.1%)"
        },
        "oi_threshold": {
          "type": ["number", "null"],
          "description": "Min open interest for liquidity check"
        },
        "leverage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 3
        }
      }
    }
  ]
}
